# Required for full functionality — all optional, app degrades gracefully

# SecurityTrails (Subdomain enumeration)
SECURITYTRAILS_API_KEY=

# AbuseIPDB (IP reputation scoring)
ABUSEIPDB_API_KEY=

# VirusTotal (Malware detection & domain/IP scoring)
VIRUSTOTAL_API_KEY=

# URLScan.io (Website scanning & screenshots) - optional, falls back to anonymous
URLSCAN_API_KEY=

# AlienVault OTX (Threat pulses)
OTX_API_KEY=

# Hunter.io (Email pattern discovery)
HUNTER_API_KEY=

# Have I Been Pwned (Email breach checks) - domain checks are free
HIBP_API_KEY=

# Sherlock (Username enumeration) - For self-hosted instance
SHERLOCK_API_URL=http://localhost:8080

# Note: The following work out of the box with NO key:
# - DNS (Node built-in)
# - crt.sh (Certificate Transparency)
# - Shodan InternetDB (Free IP lookup)
# - ip-api.com (IP Geolocation)
# - BGPView (ASN lookup)
# - HackerTarget (Free tier traceroute/port scan)
